# NAS credentials template — copy to ``credentials.local`` and fill in.
#
# IMPORTANT: ``credentials.local`` is in .gitignore and Claude is instructed
# never to read it. Claude can RUN scripts that source this file (they
# inherit env vars from the shell), but the file's contents stay local.
#
# Choose either SSH-key auth (recommended) or password auth. Don't fill in
# both — leave the unused one blank.

# ---- Connection ------------------------------------------------------
NAS_HOST=192.168.2.34
NAS_USER=                       # your DSM username, e.g. admin
NAS_SSH_PORT=22                 # change if DSM SSH listens on a non-default port

# ---- Authentication: pick ONE ---------------------------------------

# (A) SSH key — RECOMMENDED. Generate with:
#     ssh-keygen -t ed25519 -f ~/.ssh/nas_tradingagents
# then paste the .pub file into DSM → Control Panel → Terminal & SNMP →
# Authorized Keys (or ~/.ssh/authorized_keys via SSH).
NAS_SSH_KEY=                    # path to private key, e.g. ~/.ssh/nas_tradingagents

# (B) Password — fallback. Requires sshpass on the local machine
# (Git Bash: use scoop/choco to install, or run from WSL where it's a
# one-line apt install).
NAS_PASSWORD=

# ---- Project location on the NAS ------------------------------------
NAS_REPO_PATH=/volume1/docker/tradingagents
NAS_DATA_PATH=/volume1/docker/tradingagents/data

# ---- Optional: which git remote to pull from ------------------------
# Defaults to whatever ``origin`` is set to on the NAS clone, which will
# be your fork after the initial deploy.
NAS_GIT_REMOTE=origin
NAS_GIT_BRANCH=main
