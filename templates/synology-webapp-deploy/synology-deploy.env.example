# Project metadata for the Synology deploy scripts. Committed to the
# repo (no secrets here — secrets live in credentials.local). Copy to
# ``scripts/nas/synology-deploy.env`` and fill in for each new project.

# ---- Identity --------------------------------------------------------
PROJECT_NAME=myproject
NAS_REPO_PATH=/volume1/docker/myproject
NAS_DATA_PATH=/volume1/docker/myproject/data

# ---- Git source ------------------------------------------------------
# The fork URL the NAS clones from. After the first deploy, the on-NAS
# clone uses ``origin`` as configured here.
FORK_URL=https://github.com/<YOUR_USER>/<REPO>.git
NAS_GIT_REMOTE=origin
NAS_GIT_BRANCH=main

# ---- Services to deploy ---------------------------------------------
# Space-separated list of docker-compose service names that ``deploy.sh``
# / ``upgrade.sh`` should build and start. Examples:
#   DEPLOY_SERVICES="app"
#   DEPLOY_SERVICES="api web"
#   DEPLOY_SERVICES="api web worker"
DEPLOY_SERVICES="app"

# Default service for ``logs.sh`` / ``restart.sh`` when SERVICE/SERVICES
# isn't passed. First entry of DEPLOY_SERVICES is a sane choice.
DEFAULT_LOG_SERVICE="app"

# Container names used for the health-check loop in deploy.sh. Should
# match the ``container_name:`` you set in docker-compose.yml.
PRIMARY_CONTAINERS="myproject-app"

# ---- Informational --------------------------------------------------
# Printed at the end of a successful deploy so you know where to point
# your browser. Optional; leave blank if there's no web UI.
PUBLIC_URL=http://192.168.2.34:3001/
API_DOCS_URL=
