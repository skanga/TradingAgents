# NAS credentials template — copy to ``credentials.local`` and fill in.
#
# IMPORTANT: ``credentials.local`` is in .gitignore and Claude is instructed
# never to read it. Claude can RUN scripts that source this file (they
# inherit env vars from the shell), but the file's contents stay local.

# ---- Connection ------------------------------------------------------
NAS_HOST=192.168.2.34
NAS_USER=                       # your DSM username
NAS_SSH_PORT=22

# ---- Authentication: pick ONE ---------------------------------------

# (A) SSH key — RECOMMENDED. Generate once on your local machine:
#     ssh-keygen -t ed25519 -f ~/.ssh/nas_<project>
# Paste the .pub file into ~/.ssh/authorized_keys on the NAS:
#     ssh user@nas
#     mkdir -p ~/.ssh && chmod 700 ~/.ssh
#     nano ~/.ssh/authorized_keys     # paste, save
#     chmod 600 ~/.ssh/authorized_keys
NAS_SSH_KEY=                    # path to private key, e.g. ~/.ssh/nas_myproject

# (B) Password — fallback. Requires sshpass on the local machine
# (apt install sshpass / scoop install sshpass / brew install hudochenkov/sshpass/sshpass).
NAS_PASSWORD=
