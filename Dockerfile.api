# FastAPI service image. Reuses the same Python deps as the GUI (we
# install with [service] extras which include FastAPI + uvicorn +
# websockets in addition to the framework's core deps).
#
# Build:    docker compose build api
# Run:      docker compose up -d api
# Logs:     docker compose logs -f api

FROM python:3.12-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

WORKDIR /build
COPY pyproject.toml README.md ./
COPY tradingagents ./tradingagents
COPY cli ./cli
COPY gui ./gui
COPY service ./service
# Install with both extras so the API container can also render exports
# (gui modules are reused by the API as the analysis backend).
RUN pip install --no-cache-dir '.[gui,service]'

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN groupadd --gid 1000 appuser && useradd --uid 1000 --gid 1000 --create-home appuser
USER appuser
WORKDIR /home/appuser/app
COPY --from=builder --chown=appuser:appuser /build .

EXPOSE 8000
CMD ["uvicorn", "service.app:app", "--host", "0.0.0.0", "--port", "8000"]
